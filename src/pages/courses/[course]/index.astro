---
import CourseShell from '../../../layouts/CourseShell.astro';
import CourseSidebar from '../../../components/CourseSidebar.astro';
import OnThisPage from '../../../components/OnThisPage.astro';
import { loadCourses, resolveCourse, courseWelcomeContent } from '../../../lib/content';
import { href } from '../../../lib/url';

export function getStaticPaths() {
  return loadCourses().map((c) => ({ params: { course: c.id } }));
}

const { course: slug } = Astro.params;
const { course, modules } = resolveCourse(slug!);
const welcome = courseWelcomeContent(course);
const firstModule = modules[0];
const firstLesson = firstModule?.lessons[0];
---

<CourseShell title={course.title}>
  <CourseSidebar slot="sidebar" course={course} modules={modules} isWelcome={true} />

  <article class="lesson">
    <p class="crumbs"><a href={href('/')}>All courses</a></p>
    <h1>{course.title}</h1>
    {course.estimatedDuration && <p class="lesson__meta">{course.estimatedDuration}</p>}

    {welcome.html && <div class="prose" set:html={welcome.html} />}

    {
      firstModule && firstLesson && (
        <p class="welcome-cta">
          <a class="btn" href={href(`/courses/${course.id}/${firstModule.id}/${firstLesson.id}/`)}>
            Start the course →
          </a>
        </p>
      )
    }
  </article>

  <OnThisPage slot="toc" headings={welcome.headings} />
</CourseShell>
