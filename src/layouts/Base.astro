---
import '../styles/global.css';
import { href } from '../lib/url';

interface Props {
  title: string;
  wide?: boolean;
}
const { title, wide = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={href('/')}>mycourses</a>
    </header>
    <main class:list={['container', { 'container--wide': wide }]}>
      <slot />
    </main>
    <footer class="site-footer">Built with Astro, deployed on GitHub Pages.</footer>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
    ></script>
    <script is:inline>
      if (window.hljs) window.hljs.highlightAll();
    </script>
  </body>
</html>
